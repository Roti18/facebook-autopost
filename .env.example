# Headless mode: set to false to see the browser GUI and log in manually on first run.
# Set to true only when the session is saved and you want to run completely in the background.
HEADLESS=false

# Directory to store user session, cookies, and localStorage.
# Relative to root directory or absolute path.
FB_USER_DATA_DIR=./user_data

# Delay constraints (in seconds) between postings in multiple groups to avoid FB spam detection.
MIN_DELAY_SECONDS=60
MAX_DELAY_SECONDS=180

# Interval limit (in minutes) to prevent double-posting to the same group too quickly.
POST_INTERVAL_MINUTES=60

# Path to the post template file containing Spintax formatting
POST_TEMPLATE_PATH=post_template.txt

# Optional: Path to an image file if you want to upload media (leave blank to post text-only)
IMAGE_PATH=
